      "source": [
        "from verbx.api import generate_ir\n",
        "from verbx.ir.generator import IRGenConfig\n",
        "\n",
        "report = generate_ir(\n",
        "    'nb_ir.wav',\n",
        "    config=IRGenConfig(mode='fdn', length=0.35, sr=24000, channels=1, seed=11),\n",
        ")\n",
        "report"
      ]
    }
